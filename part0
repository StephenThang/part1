<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes -- single page app</title>
    <style>
        body {
            font-family: sans-serif;
            padding: 20px;
        }
        h1 {
            font-size: 2rem;
            margin-bottom: 20px;
        }
        form {
            margin-top: 20px;
        }
        input[type="text"] {
            padding: 5px;
            width: 200px;
        }
        button {
            padding: 5px 15px;
            margin-left: 5px;
        }
    </style>
</head>
<body>

    <h1>Notes -- single page app</h1>

    <form id="notes-form">
        <input type="text" id="note-input" placeholder="Write a note..." required>
        <hr style="border: 0; border-top: 1px solid #ccc; margin: 10px 0; width: 250px;">
        <button type="submit">Save</button>
    </form>

</body>
</html>